# Application Configuration
ENV=development
PROJECT_NAME=SpendFlow API

# Security Configuration - REQUIRED in production
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_in_production_with_secure_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration - REQUIRED
# SQLite for development: sqlite+aiosqlite:///./test.db
# PostgreSQL for production: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./spendlyflow.db

# CORS Configuration - REQUIRED in production
# Comma-separated list of allowed origins. Example: https://example.com,https://app.example.com
# CRITICAL: Do not use * in production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Optional: Debug mode (should be False in production)
DEBUG=False